# 金融投顾素材助手 - 环境变量配置

# ========================================
# 新闻数据源配置（可选）
# ========================================

# NewsData.io API Key (免费额度: 每天200条请求)
# 获取地址: https://newsdata.io/
NEWSDATA_API_KEY=your_newsdata_api_key_here

# GNews API Key (免费额度: 每天100条请求)
# 获取地址: https://gnews.io/
GNEWS_API_KEY=your_gnews_api_key_here

# ========================================
# AI 服务配置（在网页设置中配置即可）
# ========================================

# OpenAI API Key
# 获取地址: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key
# 获取地址: https://www.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ========================================
# 说明
# ========================================
# 1. 新闻API是可选的，系统会通过RSS源自动抓取新闻
# 2. AI配置建议在网页的"AI设置"中配置，仅保存在本地浏览器
# 3. 本文件仅供开发参考，实际使用时请创建 .env.local 文件
